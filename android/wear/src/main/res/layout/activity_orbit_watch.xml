<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/orbia_bg">

    <View
        android:id="@+id/pulse_ring_3"
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:background="@drawable/pulse_ring"
        android:visibility="invisible"
        android:alpha="0.3"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/transcript_scroll"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.45" />

    <View
        android:id="@+id/pulse_ring_2"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:background="@drawable/pulse_ring"
        android:visibility="invisible"
        android:alpha="0.5"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/transcript_scroll"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.45" />

    <View
        android:id="@+id/pulse_ring_1"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:background="@drawable/pulse_ring"
        android:visibility="invisible"
        android:alpha="0.7"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/transcript_scroll"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.45" />

    <ImageView
        android:id="@+id/orb_logo"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:src="@drawable/orbia_orb"
        android:contentDescription="@string/orb_description"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?android:attr/selectableItemBackgroundBorderless"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/transcript_scroll"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.4" />

    <TextView
        android:id="@+id/orbit_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/orbit_label"
        android:textColor="@color/orbia_text"
        android:textSize="10sp"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.15"
        android:alpha="0.6"
        app:layout_constraintTop_toBottomOf="@id/orb_logo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="2dp" />

    <TextView
        android:id="@+id/status_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/status_ready"
        android:textColor="@color/orbia_glow"
        android:textSize="8sp"
        android:fontFamily="sans-serif-light"
        android:letterSpacing="0.1"
        app:layout_constraintTop_toBottomOf="@id/orbit_label"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="2dp" />

    <ScrollView
        android:id="@+id/transcript_scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        android:fadingEdge="vertical"
        android:requiresFadingEdge="vertical"
        android:fadingEdgeLength="8dp"
        android:paddingHorizontal="12dp"
        android:paddingVertical="4dp"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/status_text"
        android:layout_marginTop="4dp"
        app:layout_constraintHeight_max="60dp">

        <TextView
            android:id="@+id/transcript_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/orbia_text"
            android:textSize="10sp"
            android:fontFamily="sans-serif-light"
            android:textAlignment="center"
            android:lineSpacingExtra="2dp" />

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
